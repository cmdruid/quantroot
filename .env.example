# =============================================================================
# Quantroot Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# Never commit the actual .env file.

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------

# Project prefix used for container names
COMPOSE_PROJECT_NAME=quantroot

# Network mode (regtest, signet, testnet, mainnet)
NETWORK=regtest

# -----------------------------------------------------------------------------
# Service: Bitcoin
# -----------------------------------------------------------------------------

BITCOIN_RPC_USER=quantroot
BITCOIN_RPC_PASS=quantroot
BITCOIN_RPC_PORT=18443

# -----------------------------------------------------------------------------
# Service: (add services as needed)
# -----------------------------------------------------------------------------
