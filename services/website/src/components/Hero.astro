<section class="relative overflow-hidden pt-32 pb-20 md:pt-44 md:pb-32">
  <!-- Background gradient -->
  <div
    class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--color-quantum)_0%,_transparent_50%)] opacity-10"
  ></div>

  <div class="relative mx-auto max-w-4xl px-6 text-center">
    <div
      class="mb-6 inline-flex items-center gap-2 rounded-full border border-border bg-surface-raised px-4 py-1.5 text-sm text-text-secondary"
    >
      <span class="inline-block h-2 w-2 rounded-full bg-quantum animate-pulse"></span>
       Proof of Concept &mdash; BIP 368 &amp; BIP 369
    </div>

    <h1
      class="mb-6 text-4xl leading-tight font-extrabold tracking-tight md:text-6xl md:leading-tight"
    >
      Post-Quantum Security<br />
      for <span class="text-btc-orange">Bitcoin</span> Taproot
    </h1>

    <p class="mx-auto mb-10 max-w-2xl text-lg leading-relaxed text-text-secondary md:text-xl">
      Quantroot is a soft-fork upgrade path that brings
      <strong class="text-text-primary">SPHINCS+</strong> post-quantum signatures
      to Bitcoin through Taproot &mdash; with zero cost today and full protection
      when you need it.
    </p>

    <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
      <a
        href="#how-it-works"
        class="inline-flex items-center rounded-lg bg-btc-orange px-6 py-3 text-sm font-semibold text-surface transition-colors hover:bg-btc-orange-dark"
      >
        Learn How It Works
      </a>
      <a
        href="https://github.com/cmdruid/quantroot"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-lg border border-border bg-surface-raised px-6 py-3 text-sm font-semibold text-text-primary transition-colors hover:border-text-secondary"
      >
        View on GitHub &rarr;
      </a>
    </div>
  </div>
</section>
