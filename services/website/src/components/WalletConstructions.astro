---
const constructions = [
  {
    name: "Hybrid Leaf + Key-Path",
    subtitle: "Real internal key + hybrid tapleaf",
    recommended: true,
    description: "Maximum spending efficiency with post-quantum insurance. Uses the BIP 32 child key as internal key for fast key-path spends, with a single hybrid tapleaf for emergency SPHINCS+ spending.",
    structure: [
      "Internal key: <child_schnorr_pk>",
      "Leaf A: <sphincs_pk> OP_CHECKSPHINCSVERIFY OP_DROP",
      "        <child_schnorr_pk> OP_CHECKSIG",
    ],
    pros: [
      "Key-path spending at ~64 bytes (most efficient Taproot spend)",
      "Pre-activation safe — OP_CHECKSIG always enforced in hybrid script",
      "Seed-derived SPHINCS+ key — mnemonic-only backup",
    ],
    cons: [
      "Accepted race risk: script-path spend reveals internal key to quantum attacker",
    ],
  },
  {
    name: "NUMS + Hybrid Emergency",
    subtitle: "Disabled key-path + hybrid tapleaf",
    recommended: false,
    description: "Unconditional protection against key-path quantum attacks, including mempool-speed attacks. Uses NUMS internal key to disable key-path entirely.",
    structure: [
      "Internal key: H (NUMS point)",
      "Leaf A: <schnorr_pk> OP_CHECKSIGVERIFY 1",
      "Leaf B: <sphincs_pk> OP_CHECKSPHINCSVERIFY OP_DROP",
      "        <schnorr_pk> OP_CHECKSIG",
    ],
    pros: [
      "No key-path quantum vulnerability (NUMS disables key-path)",
      "Both leaves require valid Schnorr — safe pre-activation",
    ],
    cons: [
      "Normal spending uses script-path (~130 bytes vs ~64 bytes)",
      "Two tapleaves instead of one",
    ],
  },
];
---

<section class="border-t border-border py-20 md:py-28">
  <div class="mx-auto max-w-5xl px-6">
    <div class="mb-16 text-center">
      <h2 class="mb-4 text-3xl font-bold tracking-tight md:text-4xl">
        Wallet Constructions
      </h2>
      <p class="mx-auto max-w-2xl text-text-secondary">
        Two strategies for integrating post-quantum protection into Taproot
        outputs &mdash; choose based on your threat model.
      </p>
    </div>

    <div class="grid gap-8 md:grid-cols-2">
      {constructions.map((c) => (
        <div class="flex flex-col rounded-xl border border-border bg-surface-raised overflow-hidden">
          <div class="p-6 pb-0">
            <div class="mb-1 flex items-center gap-3">
              <h3 class="text-xl font-bold">{c.name}</h3>
              {c.recommended && (
                <span class="rounded-full bg-quantum/10 px-2.5 py-0.5 text-xs font-medium text-quantum">
                  Recommended
                </span>
              )}
            </div>
            <p class="mb-4 text-sm text-text-secondary">{c.subtitle}</p>
            <p class="mb-4 text-sm leading-relaxed text-text-secondary">{c.description}</p>
          </div>

          <!-- Structure -->
          <div class="mx-6 mb-4 rounded-lg bg-surface-overlay px-4 py-3">
            {c.structure.map((line) => (
              <div class="font-mono text-xs leading-relaxed text-text-secondary">{line}</div>
            ))}
          </div>

          <!-- Pros / Cons -->
          <div class="mt-auto border-t border-border p-6">
            <ul class="mb-3 space-y-1.5">
              {c.pros.map((pro) => (
                <li class="flex items-start gap-2 text-sm text-text-secondary">
                  <span class="mt-0.5 shrink-0 text-quantum">+</span>
                  {pro}
                </li>
              ))}
            </ul>
            <ul class="space-y-1.5">
              {c.cons.map((con) => (
                <li class="flex items-start gap-2 text-sm text-text-secondary">
                  <span class="mt-0.5 shrink-0 text-btc-orange">-</span>
                  {con}
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
