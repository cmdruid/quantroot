---
const benchmarks = [
  {
    label: "Schnorr Sign",
    time: "~27 \u00B5s",
    ratio: "baseline",
    note: "Standard Taproot key-path signing. The performance target for normal wallet operations.",
    tone: "btc-orange",
  },
  {
    label: "SPHINCS+ Sign",
    time: "~918 ms",
    ratio: "33,600\u00D7",
    note: "Offline wallet operation. Slower, but only used for emergency script-path spending.",
    tone: "quantum",
  },
  {
    label: "Schnorr Verify",
    time: "~27 \u00B5s",
    ratio: "baseline",
    note: "Standard Taproot signature verification. The consensus baseline for validation cost.",
    tone: "btc-orange",
  },
  {
    label: "SPHINCS+ Verify",
    time: "~1,756 \u00B5s",
    ratio: "64\u00D7",
    note: "On-chain consensus validation. The cost that matters for block verification.",
    tone: "quantum",
  },
  {
    label: "Schnorr Signature",
    time: "64 bytes",
    ratio: "16 vB",
    note: "Key-path witness: just a single Schnorr signature. The most efficient Taproot spend.",
    tone: "btc-orange",
  },
  {
    label: "SPHINCS+ Signature",
    time: "4,080 bytes",
    ratio: "1,020 vB",
    note: "Carried in the Taproot annex. Script-path witness also includes the Schnorr sig, script, and control block.",
    tone: "quantum",
  },
];
---

<section id="benchmarks" class="border-t border-border py-20 md:py-28">
  <div class="mx-auto max-w-5xl px-6">
    <div class="mb-16 text-center">
      <h2 class="mb-4 text-3xl font-bold tracking-tight md:text-4xl">
        Benchmarks
      </h2>
      <p class="mx-auto max-w-2xl text-text-secondary">
        SPHINCS+ signing and verification compared to the Schnorr baseline.
      </p>
    </div>

    <div class="mx-auto grid max-w-4xl gap-4 md:grid-cols-2">
      {benchmarks.map((item) => (
        <div class="rounded-xl border border-border bg-surface-raised p-6">
          <div class={`mb-3 text-xs font-semibold uppercase tracking-[0.18em] ${item.tone === "quantum" ? "text-quantum" : "text-btc-orange"}`}>
            {item.label}
          </div>
          <div class="mb-3 flex items-end justify-between gap-3">
            <span class="font-mono text-2xl font-bold">{item.time}</span>
            <span class={`rounded px-2 py-1 font-mono text-xs ${item.tone === "quantum" ? "bg-quantum/10 text-quantum" : "bg-btc-orange/10 text-btc-orange"}`}>
              {item.ratio}
            </span>
          </div>
          <p class="text-sm leading-relaxed text-text-secondary">{item.note}</p>
        </div>
      ))}
    </div>
  </div>
</section>
