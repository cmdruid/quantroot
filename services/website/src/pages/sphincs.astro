    animation: pulse-slow 3s ease-in-out infinite;
  }
  @keyframes pulse-slow {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.7; }
  }
</style>

<script>
  // Hash chain interaction
  document.addEventListener('DOMContentLoaded', () => {
    const chain = document.getElementById('hashChain');
    const status = document.getElementById('chainStatus');
    if (!chain || !status) return;

    const nodes = chain.querySelectorAll('.chain-node');

    chain.addEventListener('click', (e) => {
      const node = (e.target as HTMLElement).closest('.chain-node');
      if (!node) return;
      const idx = parseInt(node.getAttribute('data-index') || '0');

      nodes.forEach((n, i) => {
        const box = n.querySelector('div');
        if (!box) return;
        if (i <= idx) {
          // Revealed (signature)
          box.classList.remove('bg-surface-overlay', 'border-border', 'text-text-secondary');
          box.classList.add('bg-quantum/30', 'border-quantum/50', 'text-quantum');
        } else if (i < nodes.length - 1) {
          // Verifier hashes these
          box.classList.remove('bg-surface-overlay', 'border-border', 'text-text-secondary',
                               'bg-quantum/30', 'border-quantum/50', 'text-quantum');
          box.classList.add('bg-btc-orange/20', 'border-btc-orange/40', 'text-btc-orange');
        }
      });

      const remaining = nodes.length - 2 - idx;
      status.innerHTML = `Signed value <strong>${idx}</strong>: reveal H<sup>${idx}</sup>(s). Verifier hashes ${remaining} more times to reach public key.`;
    });

    // Merkle tree interaction
    const tree = document.getElementById('merkleTree');
    const treeStatus = document.getElementById('treeStatus');
    if (!tree || !treeStatus) return;

    const siblingOf: Record<string, string> = { l0: 'l1', l1: 'l0', l2: 'l3', l3: 'l2' };
    const parentSibling: Record<string, string> = { l0: 'h23', l1: 'h23', l2: 'h01', l3: 'h01' };

    tree.querySelectorAll('.tree-leaf').forEach((leaf) => {
      leaf.addEventListener('click', () => {
        const id = leaf.getAttribute('data-id') || '';

        // Reset all
        tree.querySelectorAll('.tree-node, .tree-leaf').forEach((el) => {
          (el as SVGElement).setAttribute('stroke', '#2a2a3a');
          (el as SVGElement).setAttribute('fill', '#12121a');
        });
        tree.querySelectorAll('.tree-edge').forEach((el) => {
          (el as SVGElement).setAttribute('stroke', '#2a2a3a');
        });

        // Highlight selected leaf
        (leaf as SVGElement).setAttribute('fill', '#8b5cf620');
        (leaf as SVGElement).setAttribute('stroke', '#8b5cf6');

        // Highlight sibling (auth path node)
        const sib = siblingOf[id];
        if (sib) {
          const sibEl = tree.querySelector(`[data-id="${sib}"]`);
          if (sibEl) {
            (sibEl as SVGElement).setAttribute('fill', '#f7931a20');
            (sibEl as SVGElement).setAttribute('stroke', '#f7931a');
          }
        }

        // Highlight parent sibling
        const ps = parentSibling[id];
        if (ps) {
          const psEl = tree.querySelector(`[data-id="${ps}"]`);
          if (psEl) {
            (psEl as SVGElement).setAttribute('fill', '#f7931a20');
            (psEl as SVGElement).setAttribute('stroke', '#f7931a');
          }
        }

        // Highlight root
        const rootEl = tree.querySelector('[data-id="root"]');
        if (rootEl) {
          (rootEl as SVGElement).setAttribute('fill', '#8b5cf620');
          (rootEl as SVGElement).setAttribute('stroke', '#8b5cf6');
        }

        treeStatus.innerHTML = `Leaf <strong>${id.toUpperCase()}</strong>: auth path = [<span style="color:#f7931a">${sib?.toUpperCase()}</span>, <span style="color:#f7931a">${ps?.toUpperCase()}</span>] → verify Root`;
      });
    });
  });
</script>
