      <!-- Section 11: Signature Anatomy -->
      <section class="mb-16">
        <h2 class="mb-6 text-2xl font-bold">Inside a 4,080-Byte Signature</h2>

        <div class="space-y-2 mb-6">
          <div class="flex items-center gap-3">
            <div class="h-6 rounded bg-quantum/30 transition-all duration-500" style="width: 0.4%"></div>
            <span class="text-xs text-text-secondary whitespace-nowrap">Randomizer (16 B)</span>
          </div>
          <div class="flex items-center gap-3">
            <div class="h-6 rounded bg-btc-orange/40 transition-all duration-500" style="width: 58.8%"></div>
            <span class="text-xs text-text-secondary whitespace-nowrap">FORS signature (2,400 B)</span>
          </div>
          <div class="flex items-center gap-3">
            <div class="h-6 rounded bg-quantum/20 transition-all duration-500" style="width: 10.1%"></div>
            <span class="text-xs text-text-secondary whitespace-nowrap">XMSS Layer 0 (416 B)</span>
          </div>
